{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": ["jest"],
    // The edge-function modules use Deno-style explicit `.ts` import specifiers.
    // Tests import the pure ones (validate/catalog), pulling them into the app
    // program, so permit `.ts` extensions here (safe under --noEmit).
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules", "supabase/functions"]
}
